# ============================================================================
# WEATHER & ENVIRONMENTAL
# ============================================================================

# OpenWeatherMap settings
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_CITY=Bengaluru
IMD_API_KEY=your_imd_api_key
IMD_API_URL=https://api.example.com/imd/weather

# ============================================================================
# POLYGON NETWORK (PoW BLOCKCHAIN)
# ============================================================================

# Network: 'mumbai' (testnet), 'polygon' (mainnet), 'localhost' (hardhat node)
BLOCKCHAIN_NETWORK=mumbai

# Mumbai Testnet RPC
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygon Mainnet RPC (production)
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygonscan API key (for contract verification)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ============================================================================
# SMART CONTRACTS (Fill after deployment)
# ============================================================================

# FIGGYPoWToken contract address (after: npm run deploy:mumbai)
POW_TOKEN_ADDRESS=0x...

# FIGGYPayoutVault contract address (after: npm run deploy:mumbai)
PAYOUT_VAULT_ADDRESS=0x...

# ============================================================================
# BLOCKCHAIN MINTING
# ============================================================================

# Private key for minting transactions (0x prefix)
# ⚠️  DANGER: This key controls all minting! Use a dedicated account!
FIGGY_MINTER_PRIVATE_KEY=0x...

# Max gas price to accept (gwei)
MAX_GAS_GWEI=50

# Minutes to wait before retrying if gas price too high
GAS_RETRY_DELAY_MINUTES=5

# ============================================================================
# IPFS / PINATA (Metadata Pinning)
# ============================================================================

# Pinata API credentials (sign up: https://app.pinata.cloud/)
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# AQI settings
CPCB_API_URL=https://api.example.com/cpcb/aqi
CPCB_API_KEY=your_cpcb_api_key
IQAIR_API_URL=https://api.airvisual.com/v2/nearest_city
IQAIR_API_KEY=your_iqair_api_key
AQI_CITY=Delhi

# Kafka settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
WEATHER_KAFKA_TOPIC=weather
WEATHER_DLQ_KAFKA_TOPIC=weather_dlq
AQI_KAFKA_TOPIC=aqi
AQI_DLQ_KAFKA_TOPIC=aqi_dlq
EVENTS_TOPIC=events
EVENTS_DLQ_TOPIC=events_dlq

# Redis settings
REDIS_URL=redis://localhost:6379/0

# Government feed connector settings
DATA_GOV_FEED=https://data.gov.in/rss
PIB_FEED=https://archive.pib.gov.in/rss/press_release.rss
STATE_FEEDS=https://state.gov.in/feeds/notifications.rss

# News feed connector settings
NEWSAPI_KEY=your_newsapi_key
GNEWS_KEY=your_gnews_key
